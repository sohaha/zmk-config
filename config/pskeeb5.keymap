        //│ A       │  S       │  D       │  F       │  G        │   │ All2            │ 4        │ 5        │ 6        │ 加号        │
            &ht LAS(A) LA(A)      &ht LAS(S) LA(S)      &ht LAS(D) LA(D)      &ht LAS(F) LA(F)      &ht LAS(G) LA(G)       &ht LCGAS(N2) LCGAS(N2)     &ht LAS(N4) LA(N4)     &ht LAS(N5) LA(N5)    &ht LAS(N6) LA(N6)      &ht LAS(KP_PLUS) LA(KP_PLUS)   
        //├──────────┼──────────┼──────────┼──────────┼──────────┤   ├────────────────┼──────────┼──────────┼──────────┼─────────────┤
        //│  Z       │  X       │  C       │  V       │  B       │   │ All1            │ 1        │ 2        │ 3        │ /           │
        //│   Z       │  X       │  C       │  V       │  B       │   │ All1            │ 1        │ 2        │ 3        │ 除号        │
           &ht LAS(Z) LA(Z)      &ht LAS(X) LA(X)      &ht LAS(C) LA(C)      &ht LAS(V) LA(V)      &ht LAS(B) LA(B)        &ht LCGAS(N1) LCGAS(N1)  &ht LAS(N1) LA(N1)     &ht LAS(N2) LA(N2)     &ht LAS(N3) LA(N3)     &ht LA(DOT) LA(KP_DIVIDE) 
        //╰──────────┴──────────┴──────────┼──────────┼──────────┤   ├──────────┼──────────┼──────────┴──────────┴──────────╯
        //           │ 保持      │ 保持     │ 保持      │ 保持      │   │ 保持     │ .        │ 0         │ 保持      │
                       &trans  &trans    &trans     &trans         &trans     &ht LAS(DOT) LA(DOT)     &ht LAS(N0) LA(N0)       &trans
        //                                 ╰──────────┴──────────╯   ╰──────────┴──────────╯
            >;
            // 编码器绑定：左侧编码器控制上下方向键，右侧编码器控制左右方向键
            sensor-bindings = <&inc_dec_kp LCGAS(UP) LCGAS(DOWN) &inc_dec_kp LCGAS(LEFT) LCGAS(RIGHT)>;
        };
    };
};
